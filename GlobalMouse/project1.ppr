program project1;

{$mode objfpc}{$H+}

uses
 {$IFDEF UNIX}
 cthreads,
 {$ENDIF}
 {$IFDEF HASAMIGA}
 athreads,
 {$ENDIF}
 Interfaces, // this includes the CT adLCL widgetset
 Forms, RootGrapherForm, objMouse, objTool, ogcBasic, ogcMapObject
 { you can add units after this };

{$R *.res}

begin
 RequireDerivedFormResource:=True;
 Application.Scaled:=True;
 Application.Initialize;
 Application.CreateForm(TRootGrapherForm, RootGrapherForm);
 Application.Run;
end.

