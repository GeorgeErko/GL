program RegistryEditor;

{$mode objfpc}{$H+}

uses
 {$IFDEF UNIX}
 cthreads,
 {$ENDIF}
 {$IFDEF HASAMIGA}
 athreads,
 {$ENDIF}
 Interfaces, // this includes the CT adLCL widgetset
 Forms, RegistryMain, ogcRegistry, ValueEditForm
 { you can add units after this };

{$R *.res}

begin
 RequireDerivedFormResource:=True;
 Application.Scaled:=True;
 Application.Initialize;
 Application.CreateForm(TRegistryMainForm, RegistryMainForm);
 Application.Run;
end.

